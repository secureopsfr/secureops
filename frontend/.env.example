############################################
# APPLICATION
############################################

# URL publique de l'application frontend
# Utilisée pour les redirections OAuth, les callbacks et certains liens générés.
# Exemple:
# http://localhost:3000 (dev)
# https://secureops.fr (prod)
NEXT_PUBLIC_APP_URL=http://localhost:3000


# Indique si l'application tourne en production
# true  → active les comportements prod
# false → environnement de développement
NEXT_PUBLIC_IS_PROD=false


############################################
# BACKEND API
############################################

# URL du gateway backend.
# Tous les appels API frontend → backend passent par cette URL.
#
# Exemple dev:
# http://localhost:8000
#
# Exemple prod:
# https://api.secureops.fr
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000


############################################
# AWS CONFIGURATION
############################################

# Région AWS utilisée par les services (Cognito, API, etc.)
# Exemple: eu-west-3 (Paris)
NEXT_PUBLIC_AWS_REGION=eu-west-3


############################################
# AWS COGNITO (AUTHENTICATION)
############################################

# ID du User Pool Cognito
# Permet de gérer les utilisateurs et l'authentification.
#
# Exemple:
# eu-west-3_xxxxxxxxx
NEXT_PUBLIC_AWS_USER_POOL_ID=eu-west-3_xxxxxxxxx


# Client ID Cognito utilisé par l'application frontend.
# Généré lors de la création d'une App Client dans Cognito.
NEXT_PUBLIC_AWS_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx


############################################
# SECURITY
############################################

# Cloudflare Turnstile site key
# Utilisée pour protéger les formulaires (signup, login, etc.)
# contre les bots.
#
# Obtenue via:
# https://dash.cloudflare.com/
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x000000000000000000000000
