# =============================================================================
# Variables d'environnement — Frontend Next.js
# Copiez ce fichier vers .env.local et renseignez les valeurs.
#   cp .env.example .env.local
# =============================================================================

# --- Gateway ---
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000

# --- AWS Cognito ---
NEXT_PUBLIC_AWS_REGION=eu-west-3
NEXT_PUBLIC_AWS_USER_POOL_ID=
NEXT_PUBLIC_AWS_CLIENT_ID=
NEXT_PUBLIC_AWS_COGNITO_DOMAIN=

# --- App URL (SEO: canonicals, sitemap, OG) ---
# En production : URL finale indexable (HTTPS, domaine définitif, sans redirection).
# En local : pour un crawl SEO (ex. Screaming Frog) sur http://localhost:3001, mettre
# la même origine (http://localhost:3001) pour que les canonicals soient indexables par le crawler.
# Sinon les canonicals pointent vers la prod et le rapport signale "Non-Indexable / Canonicalised".
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Flags ---
NEXT_PUBLIC_IS_BETA_TEST=true
NEXT_PUBLIC_IS_PROD=false
