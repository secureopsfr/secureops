# =============================================================================
# Variables d'environnement — SecureOps
# Copiez ce fichier vers .env et renseignez les valeurs.
#   cp .env.example .env
# =============================================================================

# --- PostgreSQL (dev local) ---
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=template_db

# --- Database URL (construite automatiquement par launch_dev.sh / docker-compose) ---
# Pour le dev local hors docker :
# DATABASE_URL=postgresql://user:password@localhost:5433/template_db
# Pour l'admin-service (asyncpg) :
# ADMIN_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5433/template_db

# --- Admin Metrics ---
ADMIN_METRICS_API_KEY=dev-admin-metrics-key

# --- Async jobs (scan/crawl) ---
# Secret HMAC utilisé pour hasher les X-Job-Token anonymes.
# Doit être identique pour les API + workers scan/crawl dans un même environnement.
# ASYNC_JOB_TOKEN_SECRET=change-me-with-a-long-random-secret

# --- Pseudonymisation analytics ---
# ADMIN_METRICS_USER_HASH_SECRET=changeme

# --- AWS Cognito (obligatoire pour JWT : gateway, user-service, admin-service via docker-compose) ---
# Sans pool/client, les routes protégées (ex. POST /scan/api/scan/multi-async, historique) renvoient 401.
# COGNITO_REGION=eu-west-3
# COGNITO_USER_POOL_ID=eu-west-3_xxxxxxxxx
# COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# Optionnel user-service (AdminGetUser Cognito si email absent du JWT) : AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY
# Sur EC2 avec rôle IAM sur l’instance : ne pas les définir (docker-compose n’injecte plus ces vars dans user-service).
# Si définies ailleurs et réinjectées dans le conteneur, elles remplacent le rôle et un mauvais compte → pool « inexistant ».

# --- Microsoft Graph (envoi d'emails) ---
# TENANT_ID=
# CLIENT_ID=
# CLIENT_SECRET=
# SENDER_EMAIL=

# --- Scan-service (sauvegarde historique via gateway) ---
# GATEWAY_URL=http://localhost:8000  # En Docker : http://gateway:8000

# --- Scans planifiés (user-service) ---
# SCHEDULED_SCAN_INTERVAL_SECONDS=300       # Intervalle entre cycles (défaut 5 min)
# SCHEDULED_SCAN_INITIAL_DELAY_SECONDS=10   # En dev : réduire à 10 s (évite blocage par reloads)

# --- Sécurité endpoint interne scan-service ---
# En production : définir SCAN_SERVICE_INTERNAL_API_KEY (même valeur pour user-service et scan-service).
# Si définie, le header X-Internal-Api-Key est requis pour POST /api/internal/scan/run.
# SCAN_SERVICE_INTERNAL_API_KEY=

# --- PDF Service (scan-service + gateway) ---
# URL du pdf-service pour le scan-service (export PDF). launch_dev.sh utilise http://localhost:8013.
# PDF_SERVICE_URL=http://localhost:8013
# En production : définir PDF_SERVICE_INTERNAL_API_KEY (même valeur pour gateway, scan-service et pdf-service).
# Le gateway l’ajoute en header lors du proxy vers /pdf/* ; le scan-service l’envoie ; le pdf-service l’exige.
# PDF_SERVICE_INTERNAL_API_KEY=

# --- Clés API (gateway + user-service) ---
# En production : définir USER_SERVICE_INTERNAL_API_KEY (même valeur pour gateway et user-service).
# Le gateway l'envoie pour appeler /api/internal/keys/verify ; le user-service l'exige.
# USER_SERVICE_INTERNAL_API_KEY=

# --- Sécurité endpoint interne admin-service (alertes scan) ---
# En production : définir ADMIN_SERVICE_INTERNAL_API_KEY (même valeur pour user-service et admin-service).
# Si définie, le header X-Internal-Api-Key est requis pour POST /api/internal/notifications/scan-alert.
# ADMIN_SERVICE_INTERNAL_API_KEY=

# --- Alertes scans planifiés ---
# SCAN_ALERT_REGRESSION_THRESHOLD=10   # Seuil de chute de score pour alerte (défaut 10)

# --- Frontend ---
# NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000
# NEXT_PUBLIC_AWS_REGION=eu-west-3
# NEXT_PUBLIC_AWS_USER_POOL_ID=
# NEXT_PUBLIC_AWS_CLIENT_ID=
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# FRONTEND_URL=http://localhost:3000
