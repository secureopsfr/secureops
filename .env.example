# =============================================================================
# Variables d'environnement — SecureOps
# Copiez ce fichier vers .env et renseignez les valeurs.
#   cp .env.example .env
# =============================================================================

# --- PostgreSQL (dev local) ---
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=template_db

# --- Database URL (construite automatiquement par launch_dev.sh / docker-compose) ---
# Pour le dev local hors docker :
# DATABASE_URL=postgresql://user:password@localhost:5433/template_db
# Pour l'admin-service (asyncpg) :
# ADMIN_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5433/template_db

# --- Admin Metrics ---
ADMIN_METRICS_API_KEY=dev-admin-metrics-key

# --- Pseudonymisation analytics ---
# ADMIN_METRICS_USER_HASH_SECRET=changeme

# --- AWS Cognito ---
# COGNITO_REGION=eu-west-3
# COGNITO_USER_POOL_ID=
# COGNITO_CLIENT_ID=

# --- Microsoft Graph (envoi d'emails) ---
# TENANT_ID=
# CLIENT_ID=
# CLIENT_SECRET=
# SENDER_EMAIL=

# --- Scan-service (sauvegarde historique via gateway) ---
# GATEWAY_URL=http://localhost:8000  # En Docker : http://gateway:8000

# --- Scans planifiés (user-service) ---
# SCHEDULED_SCAN_INTERVAL_SECONDS=300       # Intervalle entre cycles (défaut 5 min)
# SCHEDULED_SCAN_INITIAL_DELAY_SECONDS=10   # En dev : réduire à 10 s (évite blocage par reloads)

# --- Sécurité endpoint interne scan-service ---
# En production : définir SCAN_SERVICE_INTERNAL_API_KEY (même valeur pour user-service et scan-service).
# Si définie, le header X-Internal-Api-Key est requis pour POST /api/internal/scan/run.
# SCAN_SERVICE_INTERNAL_API_KEY=

# --- Frontend ---
# NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000
# NEXT_PUBLIC_AWS_REGION=eu-west-3
# NEXT_PUBLIC_AWS_USER_POOL_ID=
# NEXT_PUBLIC_AWS_CLIENT_ID=
# NEXT_PUBLIC_AWS_COGNITO_DOMAIN=
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# FRONTEND_URL=http://localhost:3000
