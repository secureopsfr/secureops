# =============================================================================
# Variables d'environnement User Service
# Copier ce fichier en .env et renseigner les valeurs
# =============================================================================

# ── Mode ────────────────────────────────────────────────────────────────────
IS_DOCKER=false

# ── Base de données ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5433/template_db

# ── AWS Cognito (vérification JWT + gestion users) ──────────────────────────
COGNITO_REGION=eu-west-3
COGNITO_USER_POOL_ID=eu-west-3_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_ISSUER_URL=                 # Optionnel, auto-construit depuis region + pool_id
COGNITO_JWKS_URL=                   # Optionnel, auto-construit depuis region + pool_id
AWS_ACCESS_KEY_ID=                  # Credentials IAM pour gérer les users Cognito
AWS_SECRET_ACCESS_KEY=

# ── API clés (vérification interne) ───────────────────────────────────────────
# Clé pour protéger l'endpoint /api/internal/keys/verify (appelé par le gateway).
# Définir la même valeur que USER_SERVICE_INTERNAL_API_KEY sur le gateway.
# USER_SERVICE_INTERNAL_API_KEY=exemple-secret-partagé

USER_SERVICE_INTERNAL_API_KEY=exemple-secret-partagé
