# =============================================================================
# Variables d'environnement Gateway
# Copier ce fichier en .env et renseigner les valeurs
# =============================================================================

# ── Mode ────────────────────────────────────────────────────────────────────
IS_DOCKER=false
DISABLE_AUTH_MIDDLEWARE=false        # Mettre à true pour dev sans auth

# ── AWS Cognito (vérification JWT) ──────────────────────────────────────────
COGNITO_REGION=eu-west-3
COGNITO_USER_POOL_ID=eu-west-3_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_ISSUER_URL=                 # Optionnel, auto-construit depuis region + pool_id
COGNITO_JWKS_URL=                   # Optionnel, auto-construit depuis region + pool_id

# ── Métriques admin ────────────────────────────────────────────────────────
ADMIN_METRICS_API_KEY=changeme-in-production   # ⚠️ Changer en production
ADMIN_METRICS_USER_HASH_SECRET=     # Secret HMAC pour pseudonymiser les user IDs (RGPD)

# ── PDF Service (proxy /pdf/*) ──────────────────────────────────────────────
# En production : définir la même valeur que sur pdf-service et scan-service.
# Le gateway ajoute ce header lors du proxy vers le pdf-service.
# PDF_SERVICE_INTERNAL_API_KEY=exemple

# ── User Service (clés API + quota journalier) ──────────────────────────────
# Même valeur sur gateway ET user-service. Sans ça, les scans passent mais le
# compteur « X / 50 scans » ne bouge pas (fail-open côté gateway).
# USER_SERVICE_INTERNAL_API_KEY=dev-user-service-internal-key
