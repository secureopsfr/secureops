# ── Microsoft Graph (envoi d'emails) ──────────────────────────
TENANT_ID=your-azure-tenant-id
CLIENT_ID=your-azure-client-id
CLIENT_SECRET=your-azure-client-secret
SENDER_EMAIL=contact@yourdomain.com

# ── Alertes & Monitoring ─────────────────────────────────────
# Adresse email qui recevra les notifications d'alerte.
# Si non défini, SENDER_EMAIL sera utilisé par défaut.
ADMIN_ALERT_EMAIL=admin@yourdomain.com
