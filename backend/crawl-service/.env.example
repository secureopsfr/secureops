# =============================================================================
# Variables d'environnement Crawl Service
# Copier ce fichier en .env si besoin (valeurs par défaut pour le dev local)
# =============================================================================
# Ce service utilise maintenant une base de données pour stocker les jobs async crawl.

# ── Mode ────────────────────────────────────────────────────────────────────
IS_DOCKER=false

# ── Base de données (jobs async crawl) ──────────────────────────────────────
# En dev local :
# DATABASE_URL=postgresql://user:password@localhost:5433/template_db
# En docker :
# DATABASE_URL=postgresql://user:password@postgres:5432/template_db
# DATABASE_URL=

# ── Environnement ───────────────────────────────────────────────────────────
# IS_PROD=false : autorise localhost/127.0.0.1 pour tester un serveur local.
# IS_PROD=true (défaut) : bloque les IP privées et localhost (protection SSRF).
# IS_PROD=false

# ── Async jobs (anonymes) ───────────────────────────────────────────────────
# Secret HMAC utilisé pour hasher les X-Job-Token anonymes.
# Doit être identique côté API crawl et crawl-worker.
# ASYNC_JOB_TOKEN_SECRET=change-me-with-a-long-random-secret
