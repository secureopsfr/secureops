# =============================================================================
# Variables d'environnement PDF Service
# Copier ce fichier en .env et renseigner les valeurs
# =============================================================================

# ── Mode ────────────────────────────────────────────────────────────────────
IS_DOCKER=false

# ── Base de données ─────────────────────────────────────────────────────────
# Requis par le chargement de config (create_simple_settings) ; non utilisé par ce service.
DATABASE_URL=postgresql://user:password@localhost:5433/template_db
