# =============================================================================
# Variables d'environnement PDF Service
# Copier ce fichier en .env si besoin (valeurs par défaut pour le dev local)
# =============================================================================
# Ce service n'a pas de base de données : génération de rapports PDF uniquement.

# ── Mode ────────────────────────────────────────────────────────────────────
IS_DOCKER=false

# ── Clé API interne (optionnel, recommandé en prod) ─────────────────────────
# Si définie, toutes les requêtes vers POST /api/report/pdf doivent inclure
# le header X-Internal-Api-Key avec cette valeur (gateway et scan-service l’envoient).
# PDF_SERVICE_INTERNAL_API_KEY=
